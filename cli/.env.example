# Repute CLI — Environment Configuration
# Copy to .env and fill in values

# ══════════════════════════════════════════════════════════════
#  NETWORK
# ══════════════════════════════════════════════════════════════

# Network to use: bscTestnet or bscMainnet
REPUTE_NETWORK=bscTestnet

# RPC endpoints (optional — defaults to public endpoints)
# BSC_TESTNET_RPC=https://data-seed-prebsc-1-s1.binance.org:8545/
# BSC_MAINNET_RPC=https://bsc-dataseed.binance.org/

# ══════════════════════════════════════════════════════════════
#  CONTRACT ADDRESSES
# ══════════════════════════════════════════════════════════════

# Override defaults if you deployed your own contracts
# ENTRYPOINT_ADDRESS=0x0000000071727De22E5E9d8BAf0edAc6f37da032
# VERIFIER_ADDRESS=0x31095AcE88bC37DB177da15D62788B0cFB2C4761
# PAYMASTER_ADDRESS=0x6A0c7e8d7726F906C947D2E4ae66709b24BcBc33
# RAILGUN_RELAY_ADDRESS=0x8C5b784c9B8D6b9c9A81Cd1CA4957eA398B5Ea6a

# ══════════════════════════════════════════════════════════════
#  BUNDLER
# ══════════════════════════════════════════════════════════════

# ERC-4337 bundler endpoint (Pimlico, Stackup, Alchemy)
# Without this, UserOps are simulated (mock submission)
# BUNDLER_URL=https://api.pimlico.io/v2/97/rpc?apikey=YOUR_KEY

# ══════════════════════════════════════════════════════════════
#  API KEYS (optional)
# ══════════════════════════════════════════════════════════════

# BSCScan API key — used for wallet age estimation
# BSCSCAN_API_KEY=your_key_here
