# =============================================================================
# Repute Privacy Relayer — Smart Contracts Environment Variables
# =============================================================================

# Deployer wallet private key (without 0x prefix)
# MUST have tBNB (testnet) or BNB (mainnet) for gas
DEPLOYER_PRIVATE_KEY=your_private_key_here

# BSC Testnet RPC URL (default works, or use a dedicated node)
BSC_TESTNET_RPC=https://data-seed-prebsc-1-s1.bnbchain.org:8545

# BSC Mainnet RPC URL
BSC_MAINNET_RPC=https://bsc-dataseed1.bnbchain.org

# BscScan API Key (for contract verification)
BSCSCAN_API_KEY=your_bscscan_api_key_here
