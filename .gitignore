# ==============================
# ZK Circuits (Circom / Snarkjs)
# ==============================
# Ignore generated proving keys, proving setups, and compiled WebAssembly
# (These files are usually very large and should be regenerated locally)
*.r1cs
*.ptau
*.zkey
*.wasm
*.sym
contracts/circuits/**/build/
contracts/circuits/**/*_js/
contracts/circuits/**/*_cpp/
!contracts/circuits/**/*.circom

