# =============================================================================
# Repute Privacy Relayer — Frontend Environment Variables
# =============================================================================

# --- Deployed Contract Addresses (set after running contracts deploy) ---
VITE_PAYMASTER_ADDRESS=0x0000000000000000000000000000000000000000
VITE_VERIFIER_ADDRESS=0x0000000000000000000000000000000000000000
VITE_RAILGUN_RELAY_ADDRESS=0x8C5b784c9B8D6b9c9A81Cd1CA4957eA398B5Ea6a

# --- Chain Configuration ---
# "testnet" or "mainnet"
VITE_CHAIN=testnet

# --- WalletConnect Project ID (get from https://cloud.walletconnect.com) ---
VITE_WALLETCONNECT_PROJECT_ID=your_project_id_here

# --- RPC URLs (optional overrides) ---
VITE_BSC_TESTNET_RPC=https://data-seed-prebsc-1-s1.bnbchain.org:8545
VITE_BSC_MAINNET_RPC=https://bsc-dataseed1.bnbchain.org

# --- ERC-4337 Bundler URL (optional — falls back to mock if unset) ---
# Get from Pimlico, Stackup, or Alchemy
VITE_BUNDLER_URL=

# --- BSCScan API Key (for wallet age lookup) ---
VITE_BSCSCAN_API_KEY=your_bscscan_api_key_here
